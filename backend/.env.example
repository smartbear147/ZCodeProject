# ===== 语音识别（ASR）：通过 ASR_PROVIDER 切换引擎 =====
# aliyun = 阿里云 NLS 实时流式（低延迟、逐字字幕；已验证可用，默认）
# mimo   = 小米 MiMo-V2.5-ASR 分块转写（OpenAI 兼容；分段出结果，延迟较高）
ASR_PROVIDER=aliyun

# ---- 阿里云 NLS（ASR_PROVIDER=aliyun 时必填）----
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_NLS_APP_KEY=your_nls_app_key
ALIYUN_NLS_REGION=cn-shanghai

# ---- 小米 MiMo ASR（ASR_PROVIDER=mimo 时必填）----
MIMO_API_KEY=your_mimo_api_key
MIMO_ASR_MODEL=mimo-v2.5-asr
# 官方 API 地址；Token Plan 套餐用户改用 https://token-plan-cn.xiaomimimo.com/v1
MIMO_ASR_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_ASR_LANGUAGE=auto
# 分块时长（秒）：每攒满这么长的一段音频就提交一次转写，直接决定延迟与字幕粒度
MIMO_ASR_CHUNK_SECONDS=4.0

# LLM（OpenAI 兼容接口，可切换任意服务商）
# 只需修改下面三项即可切换 LLM 服务商
#
# 智谱 GLM:
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4-plus
#
# 小米 MiMo（Token Plan 套餐用户把 BASE_URL 换成 https://token-plan-cn.xiaomimimo.com/v1）:
#   LLM_BASE_URL=https://api.xiaomimimo.com/v1
#   LLM_MODEL=mimo-pro
#
# DeepSeek:
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
# 本地 Ollama:
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=qwen2.5
#
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-plus
